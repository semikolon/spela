# spela configuration — ~/.config/spela/config.toml

# Server address (for CLI client mode)
server = "media.local:7890"

# Default Chromecast device name
default_device = "Living Room TV"

# Subtitle language ("en", "sv", "off")
subtitles = "en"

# Preferred quality
quality = "1080p"

# TMDB API key (free at themoviedb.org)
tmdb_api_key = ""

# Hostname or IP that Cast clients can fetch from (never localhost)
stream_host = "media.local"

# Media directory (temporary downloads, 10 GB cap; 20 GB host-filesystem
# free-space floor checked separately — see OPERATIONS.md "Invariants").
media_dir = "~/media"

# Server listen port
port = 7890
